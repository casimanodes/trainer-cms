HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Lokal: SQLite (Standard)
DATABASE_CLIENT=sqlite

# Strapi Cloud: PostgreSQL wird automatisch konfiguriert
# DATABASE_CLIENT=postgres
# DATABASE_URL=wird-von-strapi-cloud-gesetzt

# Frontend URL fuer CORS (Vercel Produktion)
# FRONTEND_URL=https://deine-seite.vercel.app

# Nur fuer Self-Hosting (Strapi Cloud hat eigene Media-Verwaltung):
# CLOUDINARY_NAME=dein-cloud-name
# CLOUDINARY_KEY=dein-api-key
# CLOUDINARY_SECRET=dein-api-secret
