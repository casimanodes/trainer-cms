{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "offer",
    "pluralName": "offers",
    "displayName": "Offer",
    "description": "Kursangebote"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "slug": { "type": "string", "unique": true, "required": true },
    "title": { "type": "string", "required": true },
    "shortTitle": { "type": "string" },
    "description": { "type": "text" },
    "longDescription": { "type": "text" },
    "icon": { "type": "string" },
    "badge": { "type": "string" },
    "badgeColor": { "type": "enumeration", "enum": ["primary", "blue", "green", "pink", "amber"], "default": "primary" },
    "gradient": { "type": "string" },
    "features": { "type": "text" },
    "ctaText": { "type": "string" },
    "ctaLink": { "type": "string" },
    "image": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "prices": { "type": "relation", "relation": "oneToMany", "target": "api::price.price", "mappedBy": "offer" }
  }
}
